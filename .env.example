# ============================================================
# GiftCraft Studio — Environment variables (monorepo root)
# Copy to .env and fill real values for local development.
# ============================================================

# --- App ---
APP_NAME=GiftCraft
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Ho_Chi_Minh
FRONTEND_URL=http://localhost

# --- Database (PostgreSQL) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=giftcraft_db
DB_USERNAME=giftcraft
DB_PASSWORD=secret

# --- Redis ---
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# --- Cloudflare R2 (object storage) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=giftcraft
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_DEFAULT_REGION=auto

# --- VNPay ---
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost/api/payment/vnpay/callback

# --- MoMo ---
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost/api/payment/momo/callback

# --- Meilisearch ---
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=local_master_key
SCOUT_DRIVER=meilisearch

# --- Pusher / Soketi (WebSocket) ---
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=ap1

# --- Sentry ---
SENTRY_LARAVEL_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- GHN (Giao Hang Nhanh shipping) ---
GHN_TOKEN=
GHN_SHOP_ID=
GHN_ENDPOINT=https://dev-online-gateway.ghn.vn/shiip/public-api

# --- Mail (Resend) ---
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS=no-reply@giftcraft.vn
MAIL_FROM_NAME=GiftCraft Studio
MAIL_REPLY_TO=hello@giftcraft.vn

# --- Frontend (Next.js, NEXT_PUBLIC_* exposed to browser) ---
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_SITE_URL=http://localhost
